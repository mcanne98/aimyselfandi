---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Articles</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://www.linkedin.com/in/cedricanne/" target="_blank">
				<span class="sr-only">Cedric Anne on LinkedIn</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="28" height="28">
					<path fill="currentColor" d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"/>
				</svg>
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1.5em;
		background: #0F172A;
		box-shadow: 0 2px 12px rgba(15, 23, 42, 0.4);
	}
	h2 {
		margin: 0;
		font-family: 'DM Sans', sans-serif;
		font-size: 1.1em;
		font-weight: 700;
		letter-spacing: -0.01em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: #ffffff;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 60px;
	}
	nav a {
		padding: 1em 0.6em;
		color: rgba(255, 255, 255, 0.75);
		border-bottom: 3px solid transparent;
		text-decoration: none;
		font-size: 0.95em;
		transition: color 0.2s ease;
	}
	nav a:hover {
		color: #ffffff;
	}
	nav a.active {
		color: #14B8A6;
		border-bottom-color: #14B8A6;
	}
	.social-links,
	.social-links a {
		display: flex;
		align-items: center;
		color: rgba(255, 255, 255, 0.75);
	}
	.social-links a:hover {
		color: #14B8A6;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
		nav {
			height: auto;
			flex-wrap: wrap;
			padding: 0.75rem 0;
			gap: 0;
		}
		h2 {
			flex: 1 1 100%;
			padding: 0.25rem 0 0.5rem;
		}
		.internal-links {
			flex: 1 1 100%;
			display: flex;
			gap: 0;
		}
		.internal-links a {
			padding: 0.5em 0.75em 0.5em 0;
			font-size: 0.875em;
		}
	}
</style>