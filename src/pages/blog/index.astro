---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			:root {
				--navy: #0F172A;
				--navy-mid: #1E293B;
				--navy-light: #334155;
				--teal: #14B8A6;
				--teal-dark: #0F766E;
				--gold: #F59E0B;
				--text-muted: #94A3B8;
				--text-mid: #CBD5E1;
				--border: rgba(255, 255, 255, 0.08);
			}

			body {
				font-family: 'DM Sans', sans-serif;
				background: var(--navy);
				color: #ffffff;
				margin: 0;
				padding: 0;
			}

			.page-header {
				padding: 80px 40px 60px;
				max-width: 860px;
				margin: 0 auto;
				border-bottom: 1px solid var(--border);
			}
			.eyebrow {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				font-size: 0.7rem;
				font-weight: 600;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: var(--teal);
				margin-bottom: 1.5rem;
			}
			.eyebrow::before {
				content: '';
				display: block;
				width: 24px;
				height: 2px;
				background: var(--teal);
			}
			.page-header h1 {
				font-family: 'DM Serif Display', serif;
				font-size: clamp(2rem, 4vw, 3rem);
				line-height: 1.1;
				letter-spacing: -0.02em;
				color: #ffffff;
				margin: 0 0 0.75rem 0;
			}
			.page-header p {
				font-size: 1rem;
				color: var(--text-muted);
				font-weight: 300;
				margin: 0;
			}

			main {
				max-width: 860px;
				width: calc(100% - 2rem);
				margin: 0 auto;
				padding: 60px 40px;
				box-sizing: border-box;
			}

			ul {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1.5px;
				background: var(--border);
				border-radius: 12px;
				overflow: hidden;
				list-style: none;
				margin: 0;
				padding: 0;
			}

			ul li:first-child {
				grid-column: 1 / -1;
			}

			ul li a {
				display: block;
				background: var(--navy-mid);
				padding: 2rem;
				text-decoration: none;
				transition: background 0.2s;
				height: 100%;
				box-sizing: border-box;
			}
			ul li a:hover {
				background: var(--navy-light);
			}

			ul li:first-child a {
				display: grid;
				grid-template-columns: 1fr 360px;
				gap: 2rem;
				align-items: center;
				padding: 2.5rem;
			}

			ul li img {
				width: 100%;
				height: 200px;
				object-fit: cover;
				border-radius: 8px;
				display: block;
				margin-bottom: 1.25rem;
			}
			ul li:first-child img {
				height: 100%;
				min-height: 220px;
				margin-bottom: 0;
				border-radius: 8px;
			}

			.series-tag {
				font-size: 0.65rem;
				font-weight: 600;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: var(--teal);
				display: block;
				margin-bottom: 0.6rem;
			}

			.title {
				font-family: 'DM Serif Display', serif;
				font-size: 1.1rem;
				color: #ffffff;
				line-height: 1.3;
				letter-spacing: -0.01em;
				margin: 0 0 0.5rem 0;
			}
			ul li:first-child .title {
				font-size: 1.6rem;
				margin-bottom: 0.75rem;
			}

			.description {
				font-size: 0.875rem;
				color: var(--text-muted);
				line-height: 1.6;
				font-weight: 300;
				margin: 0 0 1rem 0;
			}

			.date {
				font-size: 0.775rem;
				color: var(--text-muted);
				margin: 0;
			}

			@media (max-width: 720px) {
				.page-header { padding: 60px 1.5rem 40px; }
				main { padding: 40px 1.5rem; width: calc(100% - 3rem); }
				ul { grid-template-columns: 1fr; }
				ul li:first-child { grid-column: 1; }
				ul li:first-child a {
					grid-template-columns: 1fr;
				}
				ul li:first-child img { min-height: 180px; margin-bottom: 1.25rem; }
			}
		</style>
	</head>
	<body>
		<Header />

		<div class="page-header">
			<div class="eyebrow">All Articles</div>
			<h1>The Archive</h1>
			<p>Every piece published — sorted newest to oldest.</p>
		</div>

		<main>
			<section>
				<ul>
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								{post.data.heroImage && (
									<img src={post.data.heroImage} alt={post.data.title} />
								)}
								<div>
									{post.data.series && (
										<span class="series-tag">{post.data.series}</span>
									)}
									<h4 class="title">{post.data.title}</h4>
									{post.data.description && (
										<p class="description">{post.data.description}</p>
									)}
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</div>
							</a>
						</li>
					))}
				</ul>
			</section>
		</main>

		<Footer />
	</body>
</html>
